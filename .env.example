# Modified for LAN Party Hub; see CHANGES.md and NOTICE.md.
# Optional development overrides. Portable Windows builds detect LAN addresses
# and choose a free port automatically.
PUBLIC_CONTROLLER_ORIGIN=http://192.168.178.20:5174
VITE_SERVER_URL=http://192.168.178.20:3000

# Players may refresh, lock their phone or briefly leave Wi-Fi for two minutes.
CONNECTION_RECOVERY_MS=120000
PLAYER_RECONNECT_WINDOW_MS=120000

# Development persistence. Portable builds keep this under their data/ folder.
JSON_SNAPSHOT_PATH=./data/room-snapshots.json
